# Copy this to "config.toml" and fill in. config.toml is gitignored
# (it holds your export_key and local vault path).

vault_path    = "C:/Users/lazer/Documents/OBSIDIAN/Selfhelp"
daily_folder  = "Notes/Daily Notes"
daily_format  = "%y-%m-%d"                                   # matches Periodic Notes "YY-MM-DD"
template_path = "004 Resources/Templates/Daily Notes Template.md"

worker_url    = "https://trmnl-health.<your-subdomain>.workers.dev"
export_key    = "PASTE_THE_SAME_EXPORT_KEY_YOU_SET_ON_THE_WORKER"

backfill_days = 3      # each run re-syncs the last N days (covers missed runs / late ring syncs)

# Optional: also emit Health/<date>.md frontmatter files for the
# health-md-visualizations Obsidian plugin. Leave blank to disable.
health_folder = "Health"

# Optional: where dictated Pebble voice notes land (one file per day, sections
# for To Do / Important / Ideas / Questions / Rambles). Leave blank to disable.
# Tip: schedule `python export.py --rambles-only` every 15 min for fast sync.
rambles_folder = "Rambles"

# --- Wyze smart scale (optional) — used only by wyze_pull.py ---
# Requires `pip install wyze-sdk` and an API key from https://developer-api-console.wyze.com
# (same Wyze account). Scripted login needs authenticator-app (TOTP) 2FA; SMS/email MFA
# cannot be automated. This whole file is gitignored, so creds stay local.
[wyze]
email = "you@example.com"
password = "your-wyze-password"
key_id = "WYZE_KEY_ID"
api_key = "WYZE_API_KEY"
# totp_key = "BASE32TOTPSECRET"   # only if your Wyze account uses an authenticator app
# device_model = "JA.SC"          # only set if --debug/get_records returns nothing for your scale
tz_offset = -4                     # your UTC offset (hours), to date-stamp weigh-ins locally
