/**
 * ULTRAHUMAN WORKER // SECURE EDITION
 * - API Key is now loaded from Cloudflare Secrets (env.API_TOKEN)
 * - Includes 3-Day Audit, 7-Day History Backfill, and Trend Comparison.
 * - Uses verified JSON paths for SpO2 (98%) and Temp (34.8°C).
 */

const USER_TZ_OFFSET = 5.5; 
const BASE_URL = "https://partner.ultrahuman.com/api/v1/partner/daily_metrics";
const AUDIT_INTERVAL_MS = 3 * 24 * 60 * 60 * 1000; // 3 Days

export default {
  async fetch(request, env, ctx) {
    try {
      // 1. SECURITY CHECKS
      if (!env.KV_STORE) throw new Error("Missing KV_STORE binding");
      if (!env.API_TOKEN) throw new Error("Missing API_TOKEN secret");

      const apiKey = env.API_TOKEN;

      // 2. SETUP TIME
      const nowUTC = new Date();
      const nowUser = new Date(nowUTC.getTime() + USER_TZ_OFFSET * 3600 * 1000);
      const todayStr = nowUser.toISOString().split('T')[0];

      // 3. AUDIT CHECK (Backfill History)
      const lastAuditStr = await env.KV_STORE.get('last_audit_run');
      const lastAuditTime = lastAuditStr ? parseInt(lastAuditStr) : 0;
      let history = await env.KV_STORE.get('step_history', { type: 'json' }) || {};
      const historyIsEmpty = Object.keys(history).length < 2;

      if (Date.now() - lastAuditTime > AUDIT_INTERVAL_MS || historyIsEmpty) {
        // Run in background (passed apiKey)
        ctx.waitUntil(runFullAudit(todayStr, env, apiKey));
      }

      // 4. FETCH TODAY'S DATA
      const todayData = await fetchAndParseDay(todayStr, apiKey);
      
      // Update History Immediate
      history[todayStr] = todayData.steps;
      ctx.waitUntil(env.KV_STORE.put('step_history', JSON.stringify(history)));
      ctx.waitUntil(env.KV_STORE.put(`stats_${todayStr}`, JSON.stringify(todayData)));

      // 5. TRENDS (Compare vs Yesterday)
      const yestDate = new Date(nowUser);
      yestDate.setDate(nowUser.getDate() - 1);
      const yesterdayStr = yestDate.toISOString().split('T')[0];
      const yesterdayData = await env.KV_STORE.get(`stats_${yesterdayStr}`, { type: 'json' }) || {};

      let hrvIcon = "−";
      if (yesterdayData.hrv && todayData.hrv > 0) {
        if (todayData.hrv > yesterdayData.hrv) hrvIcon = "▲";
        else if (todayData.hrv < yesterdayData.hrv) hrvIcon = "▼";
      }

      // 6. BUILD PAYLOAD
      const chartBars = getWeeklyChart(history, nowUser);
      
      const payload = {
        meta: { last_updated: nowUser.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false }) },

        // SLEEP
        sleep_duration: formatDuration(todayData.sleepSec),
        sleep_score:    todayData.sleepScore,
        sleep_cycles:   todayData.sleepCycles,
        restorative_duration: formatDuration((todayData.remSec || 0) + (todayData.deepSec || 0)),
        rem_duration:   formatDuration(todayData.remSec),
        deep_duration:  formatDuration(todayData.deepSec),
        light_duration: formatDuration(todayData.lightSec),

        // RECOVERY
        recovery_score: todayData.recoveryScore,
        hrv:            todayData.hrv || '--',
        hrv_icon:       hrvIcon,
        rhr:            todayData.rhr || '--',
        avg_temp:       `${Number(todayData.tempVal).toFixed(1)}°C`,
        spo2:           Math.round(todayData.spo2Val) + "%",

        // ACTIVITY
        movement_idx: todayData.movementIndex,
        steps:        todayData.steps,

        // CHART
        zone_1: chartBars[0], zone_2: chartBars[1], zone_3: chartBars[2],
        zone_4: chartBars[3], zone_5: chartBars[4], zone_6: chartBars[5], zone_7: chartBars[6],

        // FOOTER
        vo2_max:         todayData.vo2Max,
        alertness_score: todayData.alertness,
        active_min:      `${todayData.activeMin}m`,
        time_in_bed:     formatDuration(todayData.timeInBedSec)
      };

      return new Response(JSON.stringify(payload), { 
        headers: { 
          "content-type": "application/json; charset=utf-8",
          "Cache-Control": "public, max-age=900" 
        } 
      });

    } catch (e) {
      return new Response(JSON.stringify({ error: e.message }), { status: 500 });
    }
  }
};

// --- CORE FETCH LOGIC ---

async function fetchAndParseDay(dateStr, apiKey) {
  const url = `${BASE_URL}?date=${dateStr}`;
  const resp = await fetch(url, { headers: { 'Authorization': apiKey } });
  
  if (!resp.ok) return getEmptyData();
  const json = await resp.json();

  const metricsRoot = json?.data?.metrics;
  if (!metricsRoot) return getEmptyData(); 
  
  const dateKey = Object.keys(metricsRoot)[0];
  const allItems = metricsRoot[dateKey];

  // EXTRACT
  const sleepModule = allItems.find(m => m.type === 'sleep')?.object;
  const stepsObj    = allItems.find(m => m.type === 'steps')?.object;
  const spo2Graph   = allItems.find(m => m.type === 'spo2')?.object; 
  const tempObj     = allItems.find(m => m.type === 'temp')?.object;
  const hrvObj      = allItems.find(m => m.type === 'hrv' || m.type === 'avg_sleep_hrv')?.object;
  const rhrObj      = allItems.find(m => m.type === 'night_rhr' || m.type === 'sleep_rhr')?.object;
  const vo2Obj      = allItems.find(m => m.type === 'vo2_max')?.object;
  const activeObj   = allItems.find(m => m.type === 'active_minutes')?.object;
  const moveObj     = allItems.find(m => m.type === 'movement_index')?.object;
  const recScoreObj = allItems.find(m => m.type === 'recovery_index')?.object;

  // PARSE
  let spo2Val = 0;
  if (sleepModule?.spo2?.value) spo2Val = sleepModule.spo2.value; // Correct Path
  else spo2Val = getAverage(spo2Graph, true);

  let tempVal = 0;
  if (sleepModule?.average_body_temperature?.celsius) tempVal = sleepModule.average_body_temperature.celsius; // Correct Path
  else tempVal = getAverage(tempObj);

  let sleepScore = '--';
  if (sleepModule?.sleep_score?.score) sleepScore = sleepModule.sleep_score.score; // Correct Path
  else if (sleepModule?.score) sleepScore = sleepModule.score;

  let sleepCycles = '--';
  if (sleepModule?.full_sleep_cycles?.cycles) sleepCycles = sleepModule.full_sleep_cycles.cycles;

  let alertness = '--';
  if (sleepModule?.morning_alertness?.index) alertness = sleepModule.morning_alertness.index;
  else if (sleepModule?.alertness_index) alertness = sleepModule.alertness_index;

  return {
    steps: getValue(stepsObj, 'total'),
    hrv: Math.round(getValue(hrvObj, 'avg')) || 0,
    rhr: getValue(rhrObj, 'avg'),
    vo2Max: getValue(vo2Obj),
    recoveryScore: getValue(recScoreObj),
    movementIndex: getValue(moveObj),
    activeMin: getValue(activeObj, 'total') || getValue(activeObj) || 0,
    
    // Sleep Stats
    sleepScore: sleepScore,
    sleepCycles: sleepCycles,
    alertness: alertness,
    sleepSec: getDurationInSeconds(sleepModule, 'total_sleep'),
    remSec: getDurationInSeconds(sleepModule, 'rem_sleep'),
    deepSec: getDurationInSeconds(sleepModule, 'deep_sleep'),
    lightSec: getDurationInSeconds(sleepModule, 'light_sleep'),
    timeInBedSec: getDurationInSeconds(sleepModule, 'time_in_bed'),
    
    // Bio Stats
    spo2Val: spo2Val,
    tempVal: tempVal
  };
}

// --- AUDIT SYSTEM ---

async function runFullAudit(todayStr, env, apiKey) {
  const dates = [];
  const today = new Date(todayStr);
  for (let i = 1; i <= 7; i++) {
    const d = new Date(today);
    d.setDate(today.getDate() - i);
    dates.push(d.toISOString().split('T')[0]);
  }

  const results = await Promise.all(dates.map(date => fetchAndParseDay(date, apiKey)));
  const history = await env.KV_STORE.get('step_history', { type: 'json' }) || {};
  
  for (let i = 0; i < dates.length; i++) {
    const date = dates[i];
    const data = results[i];
    history[date] = data.steps; 
    await env.KV_STORE.put(`stats_${date}`, JSON.stringify(data)); 
  }

  await env.KV_STORE.put('step_history', JSON.stringify(history));
  await env.KV_STORE.put('last_audit_run', Date.now().toString());
}

// --- HELPERS ---

function getEmptyData() {
  return { steps: 0, hrv: 0, rhr: 0, sleepSec: 0 };
}

function getDurationInSeconds(moduleObj, key) {
  if (!moduleObj || !moduleObj[key]) return 0;
  if (moduleObj[key].seconds) return moduleObj[key].seconds;
  if (moduleObj[key].minutes) return moduleObj[key].minutes * 60;
  return 0;
}

function getValue(obj, preferredKey = 'value') {
  if (!obj) return 0;
  if (typeof obj === 'object') {
    return obj[preferredKey] || obj.value || obj.avg || obj.total || 0;
  }
  return obj; 
}

function getAverage(obj, ignoreZeros = false) {
  if (!obj) return 0;
  if (obj.avg) return obj.avg;
  if (obj.value) return obj.value;
  if (Array.isArray(obj.values)) {
    let valid = obj.values;
    if (ignoreZeros) valid = valid.filter(v => v.value > 0);
    if (valid.length === 0) return 0;
    const sum = valid.reduce((a, b) => a + b.value, 0);
    return sum / valid.length;
  }
  return 0;
}

function formatDuration(seconds) {
  if (!seconds || seconds <= 0) return "--";
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  return `${h}h ${m.toString().padStart(2, '0')}m`;
}

function getWeeklyChart(history, today) {
  const dayOfWeek = today.getDay(); 
  const diffToMon = (dayOfWeek === 0 ? -6 : 1) - dayOfWeek;
  const monday = new Date(today);
  monday.setDate(today.getDate() + diffToMon);
  const chartPercentages = [];
  for (let i = 0; i < 7; i++) {
    const d = new Date(monday); d.setDate(monday.getDate() + i);
    const dStr = d.toISOString().split('T')[0];
    let p = Math.round(((history[dStr] || 0) / 10000) * 100);
    chartPercentages.push(Math.min(p, 100));
  }
  return chartPercentages;
} 
